---
const navLinks = [
  {
    label: 'Solutions',
    href: '/solutions',
    children: ['Urbanice App', 'The LivingOS PMS', 'GuardOS', 'Services', 'API Solution'],
  },
  { label: 'Company', href: '/company' },
  { label: 'Blog', href: '/blog' },
];
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="container-los">
    <nav class="flex items-center justify-between h-16 lg:h-18">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <img src="/logo-livingos.svg" alt="The LivingOS" width="32" height="32" style="border-radius:9px;display:block;" />
        <span class="font-semibold text-text-1 text-base tracking-tight">The LivingOS</span>
      </a>

      <!-- Desktop Nav Pills -->
      <div class="hidden lg:flex items-center gap-1 bg-warm-overlay border border-warm-border-light rounded-lg px-1 py-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-4 py-1.5 text-sm font-medium text-text-3 rounded-md transition-all hover:text-text-1 hover:bg-white hover:shadow-sm"
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Desktop Right CTAs -->
      <div class="hidden lg:flex items-center gap-3">
        <a
          href="/login"
          class="text-sm font-medium text-text-2 hover:text-text-1 transition-colors px-3 py-1.5"
        >
          Log in
        </a>
        <a
          href="/demo"
          class="btn-3d px-4 py-2 text-sm font-semibold text-white bg-primary rounded-md"
        >
          ขอ Demo
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="hamburger"
        class="lg:hidden flex flex-col gap-1.5 p-2 rounded-md hover:bg-warm-surface transition-colors"
        aria-label="Toggle menu"
      >
        <span class="hamburger-line w-5 h-0.5 bg-text-2 rounded transition-all duration-300 block"></span>
        <span class="hamburger-line w-5 h-0.5 bg-text-2 rounded transition-all duration-300 block"></span>
        <span class="hamburger-line w-4 h-0.5 bg-text-2 rounded transition-all duration-300 block"></span>
      </button>
    </nav>
  </div>

  <!-- Mobile Drawer -->
  <div
    id="mobile-drawer"
    class="lg:hidden fixed inset-0 top-16 bg-warm-page border-t border-warm-border-light z-40 translate-x-full transition-transform duration-300 ease-in-out"
  >
    <div class="container-los py-6 flex flex-col gap-2">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="py-3 px-4 text-base font-medium text-text-2 hover:text-primary hover:bg-primary-50 rounded-lg transition-all"
        >
          {link.label}
        </a>
      ))}
      <div class="h-px bg-warm-border-light my-2"></div>
      <a
        href="/login"
        class="py-3 px-4 text-base font-medium text-text-2 hover:text-text-1 rounded-lg transition-all"
      >
        Log in
      </a>
      <a
        href="/demo"
        class="btn-3d mt-2 py-3 px-4 text-base font-semibold text-white bg-primary rounded-lg text-center"
      >
        ขอ Demo ฟรี
      </a>
    </div>
  </div>
</header>

<!-- Spacer for fixed navbar -->
<div class="h-16 lg:h-18"></div>

<script>
  const navbar = document.getElementById('navbar')!;
  const hamburger = document.getElementById('hamburger')!;
  const drawer = document.getElementById('mobile-drawer')!;
  let isOpen = false;

  // Scroll: transparent → white+shadow
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      navbar.classList.add('bg-white/95', 'backdrop-blur-sm', 'shadow-sm');
    } else {
      navbar.classList.remove('bg-white/95', 'backdrop-blur-sm', 'shadow-sm');
    }
  });

  // Mobile drawer toggle
  hamburger.addEventListener('click', () => {
    isOpen = !isOpen;
    if (isOpen) {
      drawer.classList.remove('translate-x-full');
      drawer.classList.add('translate-x-0');
    } else {
      drawer.classList.add('translate-x-full');
      drawer.classList.remove('translate-x-0');
    }
  });
</script>
