---
---

<section class="section-pad bg-warm-surface">
  <div class="container-los">
    <div
      class="relative overflow-hidden rounded-2xl bg-primary px-8 py-14 lg:px-16 text-center reveal-up"
      style="background: linear-gradient(135deg, #1C70F7 0%, #1560D8 60%, #1048A8 100%);"
    >
      <!-- Subtle pattern overlay -->
      <div
        class="absolute inset-0 pointer-events-none"
        style="background-image: radial-gradient(circle, rgba(255,255,255,.08) 1px, transparent 1px); background-size: 28px 28px;"
      ></div>
      <!-- Glow blob -->
      <div
        class="absolute -top-20 -right-20 w-72 h-72 rounded-full pointer-events-none"
        style="background: radial-gradient(circle, rgba(249,115,22,.25) 0%, transparent 70%);"
      ></div>

      <div class="relative z-10 flex flex-col items-center gap-6 max-w-2xl mx-auto">
        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/15 border border-white/25 text-white font-mono text-xs uppercase tracking-widest">
          <span class="w-1.5 h-1.5 rounded-full bg-orange animate-pulse"></span>
          พร้อมเริ่มต้นแล้วหรือยัง?
        </div>

        <!-- Headline -->
        <h2 class="text-3xl lg:text-4xl font-bold text-white leading-tight">
          ลองใช้ LivingOS ฟรี<br />
          <span style="color: rgba(255,237,213,1);">30 วัน ไม่ต้องใช้บัตรเครดิต</span>
        </h2>
        <p class="text-base font-light text-white/80 leading-relaxed">
          Start your free trial today. No credit card required, no setup fee.<br />
          Our team will onboard you and your staff within 7 business days.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a
            href="/demo"
            class="btn-3d px-6 py-3 text-sm font-semibold text-primary bg-white rounded-lg"
          >
            ขอ Demo ฟรี
          </a>
          <a
            href="/company#contact"
            class="px-6 py-3 text-sm font-semibold text-white bg-transparent border border-white/40 rounded-lg hover:bg-white/10 transition-all"
          >
            ติดต่อทีมงาน
          </a>
        </div>

        <!-- Trust signals -->
        <div class="flex flex-wrap items-center justify-center gap-5 text-xs text-white/60 font-mono">
          <span class="flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            ไม่มีค่าใช้จ่ายซ่อนเร้น
          </span>
          <span class="flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            ยกเลิกได้ทุกเมื่อ
          </span>
          <span class="flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            ทีม Support คนไทย
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
