<style>
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* ── Gold plate eyebrow ── */
  .eyebrow-gold {
    position: relative;
    overflow: hidden;
    padding: 6px 18px;
    border-radius: 9999px;
    border: 1.5px solid rgba(180, 130, 0, 0.45);
    background: linear-gradient(
      135deg,
      #F5E27A 0%,
      #E8C840 18%,
      #F0D060 35%,
      #C9A000 55%,
      #E8C840 72%,
      #F5E27A 88%,
      #D4A820 100%
    );
    box-shadow:
      0 1px 0 rgba(255,255,255,.55) inset,
      0 -1px 0 rgba(100,65,0,.18) inset,
      0 4px 16px rgba(180,130,0,.28),
      0 1px 4px rgba(180,130,0,.20);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .10em;
    text-transform: uppercase;
    cursor: default;
    user-select: none;
  }

  .eyebrow-gold-text {
    color: #4A2E00;
    position: relative;
    z-index: 1;
    text-shadow: 0 1px 0 rgba(255,230,100,.6);
  }

  /* Sweep shimmer */
  .eyebrow-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 30%,
      rgba(255,255,255,.55) 50%,
      transparent 70%
    );
    background-size: 220% 100%;
    background-position: -100% 0;
    animation: gold-shimmer 3.5s ease-in-out infinite;
    border-radius: 9999px;
  }

  @keyframes gold-shimmer {
    0%   { background-position: -120% 0; }
    40%  { background-position: 220% 0; }
    100% { background-position: 220% 0; }
  }

  .tab-btn {
    transition: all .18s ease;
  }

  .tab-btn.active {
    background: var(--color-white) !important;
    color: var(--color-text-1) !important;
    border-color: var(--color-warm-border-light) !important;
    box-shadow: var(--shadow-sm) !important;
  }

  .tab-btn:not(.active):hover {
    background: rgba(255,255,255,.5) !important;
    color: var(--color-text-2) !important;
  }

  .mockup-screen {
    width: 100%;
    transition: opacity .25s ease;
  }

  /* ── Mobile: icon-only tabs + video mockup ── */
  .mockup-mobile { display: none; }
  .eyebrow-text-short { display: none; }

  @media (max-width: 450px) {
    .tab-label { display: none; }

    .tab-btn {
      padding: 9px 12px !important;
      gap: 0 !important;
    }

    .mockup-desktop { display: none; }
    .mockup-mobile  { display: block; }

    .eyebrow-text-full  { display: none; }
    .eyebrow-text-short { display: inline; }
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const urlEl = document.getElementById('browser-url')!;

  const urlMap: Record<string, string> = {
    pms: 'pms.thelivingos.com',
    urbanice: 'urbanice.thelivingos.com',
    guardos: 'guardos.thelivingos.com',
    ivote: 'ivote.thelivingos.com/agm2568',
  };

  function resetTab(tab: HTMLButtonElement) {
    tab.classList.remove('active');
    tab.style.background = 'transparent';
    tab.style.color = 'var(--color-text-3)';
    tab.style.border = '1.5px solid transparent';
    tab.style.boxShadow = 'none';
    tab.style.fontWeight = '500';
    const iconSpan = tab.querySelector<HTMLSpanElement>('span:first-of-type');
    if (iconSpan) {
      iconSpan.style.background = 'var(--color-warm-surface)';
      iconSpan.style.border = 'none';
    }
    const svg = tab.querySelector('svg');
    if (svg) svg.setAttribute('stroke', '#9A9A9A');
  }

  function activateTab(tab: HTMLButtonElement) {
    tab.classList.add('active');
    tab.style.background = '#ffffff';
    tab.style.color = 'var(--color-text-1)';
    tab.style.border = '1.5px solid var(--color-warm-border-light)';
    tab.style.boxShadow = 'var(--shadow-sm)';
    tab.style.fontWeight = '600';
    const iconSpan = tab.querySelector<HTMLSpanElement>('span:first-of-type');
    if (iconSpan) {
      iconSpan.style.background = 'var(--color-primary-50)';
      iconSpan.style.border = '1.5px solid var(--color-primary-100)';
    }
    const svg = tab.querySelector('svg');
    if (svg) svg.setAttribute('stroke', '#1560D8');
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const id = tab.dataset.tab!;

      // Reset all tabs then activate the clicked one
      tabs.forEach(t => resetTab(t));
      activateTab(tab);

      // Update URL bar
      urlEl.textContent = urlMap[id] ?? 'thelivingos.com';

      // Switch screens with fade
      document.querySelectorAll<HTMLElement>('.mockup-screen').forEach(s => {
        s.style.opacity = '0';
        setTimeout(() => { s.style.display = 'none'; }, 200);
      });

      const target = document.getElementById(`screen-${id}`)!;
      setTimeout(() => {
        target.style.display = 'flex';
        requestAnimationFrame(() => { target.style.opacity = '1'; });
      }, 220);
    });
  });
</script>
