---
---

<section class="relative overflow-hidden" style="background:var(--color-warm-page); min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:120px 24px 80px; text-align:center;">

  <!-- Background: Bangkok cityscape photo -->
  <div class="absolute inset-0 pointer-events-none" style="background:url('/bangkok-hero.jpg') center 38% / cover no-repeat;filter:saturate(1.4) brightness(1.06);"></div>

  <!-- Background: Warm gradient mask -->
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 88% 72% at 55% 42%,transparent 0%,rgba(250,249,246,.55) 45%,rgba(250,249,246,.88) 100%),linear-gradient(to bottom,rgba(250,249,246,.97) 0%,rgba(250,249,246,.30) 18%,rgba(250,249,246,.25) 65%,rgba(250,249,246,.97) 100%);"></div>

  <div class="relative z-10 w-full" style="max-width:1120px; margin:0 auto;">

    <!-- Eyebrow — Gold plate -->
    <div class="hero-word eyebrow-gold inline-flex items-center gap-2 mb-7">
      <!-- Trophy icon -->
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0;opacity:.85;">
        <path d="M6 9H4a2 2 0 0 1-2-2V5h4" stroke="#7A4F00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M18 9h2a2 2 0 0 0 2-2V5h-4" stroke="#7A4F00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M6 2h12v7a6 6 0 0 1-12 0V2Z" fill="rgba(122,79,0,.12)" stroke="#7A4F00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M12 15v4" stroke="#7A4F00" stroke-width="2" stroke-linecap="round"/>
        <path d="M8 22h8" stroke="#7A4F00" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <span class="eyebrow-gold-text"><span class="eyebrow-text-full">Property Management System · No.1 in Thailand</span><span class="eyebrow-text-short">PMS No.1 IN THAILAND</span></span>
      <!-- Shimmer overlay -->
      <span class="eyebrow-shimmer" aria-hidden="true"></span>
    </div>

    <!-- One-liner headline -->
    <h1 class="hero-word" style="font-size:clamp(44px,7vw,72px);font-weight:700;line-height:1.07;letter-spacing:-.03em;color:var(--color-text-1);margin-bottom:22px;">
      บริหารนิติบุคคล<em style="font-style:normal;color:var(--color-primary);">ได้ฉลาดกว่าเดิม</em>
    </h1>

    <!-- CTAs -->
    <div class="hero-cta" style="display:flex;gap:12px;align-items:center;justify-content:center;flex-wrap:wrap;margin-bottom:52px;">
      <a href="/demo" class="btn-3d" style="display:inline-flex;align-items:center;gap:7px;font-family:var(--font-sans);font-size:15px;font-weight:600;color:#fff;background:var(--color-primary);border:none;padding:13px 28px;border-radius:12px;text-decoration:none;cursor:pointer;">
        เริ่มใช้งานฟรี 30 วัน
      </a>
      <a href="#how" style="display:inline-flex;align-items:center;gap:8px;font-family:var(--font-sans);font-size:15px;font-weight:500;color:var(--color-text-2);background:#ffffff;border:1.5px solid var(--color-warm-border-light);padding:13px 28px;border-radius:12px;text-decoration:none;cursor:pointer;transition:all .18s;box-shadow:0 1px 4px rgba(60,45,20,.09),0 1px 2px rgba(60,45,20,.06);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg>
        ดูวิดีโอการทำงาน
      </a>
    </div>

    <!-- Trust row — floating pill badges -->
    <div class="hero-cta" style="display:flex;align-items:center;gap:10px;justify-content:center;flex-wrap:wrap;margin-bottom:64px;">
      <div style="display:inline-flex;align-items:center;gap:7px;padding:8px 16px;border-radius:9999px;background:#ffffff;border:1.5px solid var(--color-warm-border-light);box-shadow:0 2px 10px rgba(60,45,20,.10),0 1px 3px rgba(60,45,20,.07);font-size:13px;font-weight:500;color:var(--color-text-2);">
        <span style="width:7px;height:7px;border-radius:50%;background:#16A34A;display:inline-block;flex-shrink:0;box-shadow:0 0 0 3px rgba(22,163,74,.15);"></span>ไม่ต้องใช้บัตรเครดิต
      </div>
      <div style="display:inline-flex;align-items:center;gap:7px;padding:8px 16px;border-radius:9999px;background:#ffffff;border:1.5px solid var(--color-warm-border-light);box-shadow:0 2px 10px rgba(60,45,20,.10),0 1px 3px rgba(60,45,20,.07);font-size:13px;font-weight:500;color:var(--color-text-2);">
        <span style="width:7px;height:7px;border-radius:50%;background:#16A34A;display:inline-block;flex-shrink:0;box-shadow:0 0 0 3px rgba(22,163,74,.15);"></span>ติดตั้งได้ภายใน 1 วัน
      </div>
      <div style="display:inline-flex;align-items:center;gap:7px;padding:8px 16px;border-radius:9999px;background:#ffffff;border:1.5px solid var(--color-warm-border-light);box-shadow:0 2px 10px rgba(60,45,20,.10),0 1px 3px rgba(60,45,20,.07);font-size:13px;font-weight:500;color:var(--color-text-2);">
        <span style="width:7px;height:7px;border-radius:50%;background:#16A34A;display:inline-block;flex-shrink:0;box-shadow:0 0 0 3px rgba(22,163,74,.15);"></span>รองรับโครงการทุกขนาด
      </div>
    </div>

    <!-- ── Product Tab Strip ───────────────────────────────────────────── -->
    <div class="hero-mockup">

      <!-- Tab buttons -->
      <div id="product-tabs" style="display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:0;padding:6px;background:var(--color-warm-overlay);border:1.5px solid var(--color-warm-border-light);border-radius:16px 16px 0 0;width:fit-content;margin:0 auto;position:relative;z-index:2;">

        <button class="tab-btn active" data-tab="pms" style="display:flex;align-items:center;gap:9px;padding:9px 20px;border-radius:12px;border:none;cursor:pointer;font-family:var(--font-sans);font-size:13px;font-weight:600;transition:all .18s;background:var(--color-white);color:var(--color-text-1);border:1.5px solid var(--color-warm-border-light);box-shadow:var(--shadow-sm);">
          <span style="width:22px;height:22px;border-radius:7px;display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden;">
