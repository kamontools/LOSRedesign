---
const faqs = [
  {
    q: 'LivingOS เหมาะกับโครงการขนาดไหน?',
    a: 'LivingOS รองรับโครงการทุกขนาด ตั้งแต่โครงการเล็ก 50 ยูนิต ไปจนถึง Multi-site หลายพันยูนิต โดยแผน Starter เหมาะสำหรับโครงการน้อยกว่า 100 ยูนิต และ Enterprise สำหรับองค์กรขนาดใหญ่',
    aEN: 'LivingOS supports all project sizes — from 50-unit condos to multi-site enterprise portfolios.',
  },
  {
    q: 'ติดตั้งและเริ่มใช้งานนานแค่ไหน?',
    a: 'โดยเฉลี่ยโครงการสามารถ Go Live ได้ภายใน 7 วัน สำหรับโครงการที่ต้องการการปรับแต่ง หรือ Turnkey Setup อาจใช้เวลา 2–4 สัปดาห์ ทีมงานเราจะ Onboard และฝึกใช้งานให้ครบ',
    aEN: 'Most projects go live within 7 days. Complex or turnkey setups may take 2–4 weeks with full onboarding support.',
  },
  {
    q: 'ข้อมูลลูกบ้านจากระบบเก่าย้ายมาได้ไหม?',
    a: 'ได้เลย ทีมงานช่วย Migrate ข้อมูลจาก Excel, CSV หรือระบบเดิม เช่น SAP, Sage ฯลฯ ให้ฟรี ไม่มีค่าใช้จ่ายเพิ่มเติมในทุกแผน',
    aEN: 'Yes — we migrate data from Excel, CSV, or legacy systems (SAP, Sage, etc.) at no extra cost.',
  },
  {
    q: 'มีการฝึกอบรมพนักงานไหม?',
    a: 'ทุกแผนได้รับ Onboarding Session ทางออนไลน์ แผน Professional ขึ้นไปได้ 2 ครั้ง และ Enterprise ได้ Dedicated Training ไม่จำกัด นอกจากนี้ยังมี Academy สำหรับ self-paced learning',
    aEN: 'All plans include online onboarding. Professional gets 2 sessions, Enterprise gets unlimited dedicated training plus Academy access.',
  },
  {
    q: 'ระบบ Offline ได้ไหม ถ้า Internet หลุด?',
    a: 'Urbanice App รองรับ Offline Mode สำหรับฟีเจอร์หลัก เช่น ดูใบแจ้งหนี้ที่โหลดไว้แล้ว ส่วน PMS ต้องการการเชื่อมต่อเพื่อความถูกต้องของข้อมูล แต่มี Cache ช่วยลด Downtime Impact',
    aEN: 'Urbanice App supports offline mode for core features. PMS requires connection for data accuracy but has cache to reduce downtime impact.',
  },
  {
    q: 'ต่อ API กับระบบภายนอกได้ไหม?',
    a: 'ได้ LivingOS มี REST API ครอบคลุม เช่น ดึงข้อมูลลูกบ้าน ใบแจ้งหนี้ และ Webhook สำหรับ Event-driven Integration เช่น Line OA, ERP, Payment Gateway ฯลฯ',
    aEN: 'Yes — REST API covers residents, invoices, and webhooks for Line OA, ERP, and payment gateway integrations.',
  },
  {
    q: 'ราคารวม VAT หรือเปล่า?',
    a: 'ราคาที่แสดงยังไม่รวม VAT 7% ใบเสร็จออกในนามบริษัทสามารถนำไปลงต้นทุนได้ตามปกติ',
    aEN: 'Displayed prices exclude 7% VAT. Tax invoices are issued for accounting purposes.',
  },
  {
    q: 'ถ้าไม่พอใจ ยกเลิกได้ไหม?',
    a: 'ได้เลย ยกเลิกได้ทุกเมื่อโดยไม่มีค่าปรับ ข้อมูลทั้งหมดจะส่งคืนในรูปแบบ CSV ภายใน 30 วันหลังยกเลิก',
    aEN: 'Cancel anytime, no penalties. All data is returned as CSV within 30 days of cancellation.',
  },
];
---

<section class="section-pad bg-warm-page">
  <div class="container-los">
    <!-- Header -->
    <div class="text-center mb-14 reveal-up">
      <div class="overline mb-3">FAQ</div>
      <h2 class="text-3xl lg:text-4xl font-bold text-text-1 mb-4">
        คำถามที่พบบ่อย
      </h2>
      <p class="text-md text-text-3 font-light max-w-lg mx-auto">
        Can't find your answer here? <a href="/company#contact" class="text-primary underline underline-offset-2">Contact our team</a> — we reply within 1 business hour.
      </p>
    </div>

    <!-- FAQ accordion -->
    <div class="max-w-3xl mx-auto flex flex-col gap-2 reveal-stagger" id="faq-list">
      {faqs.map((faq, i) => (
        <div
          class="faq-item border border-warm-border-light rounded-xl bg-white overflow-hidden transition-shadow duration-200"
          data-index={i}
        >
          <button
            class="faq-trigger w-full flex items-start justify-between gap-4 p-5 text-left hover:bg-warm-page transition-colors"
            aria-expanded="false"
          >
            <span class="font-medium text-text-1 text-sm leading-relaxed">{faq.q}</span>
            <svg
              class="faq-icon w-5 h-5 text-text-4 shrink-0 mt-0.5 transition-transform duration-300"
              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round"
            >
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>
          <div class="faq-answer overflow-hidden" style="height: 0;">
            <div class="px-5 pb-5">
              <p class="text-sm text-text-2 leading-relaxed">{faq.a}</p>
              <p class="text-xs text-text-4 mt-2 italic">{faq.aEN}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const triggers = document.querySelectorAll<HTMLButtonElement>('.faq-trigger');

  triggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item')!;
      const answer = item.querySelector<HTMLElement>('.faq-answer')!;
      const icon = trigger.querySelector<SVGElement>('.faq-icon')!;
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      // Close all others
      triggers.forEach((t) => {
        if (t !== trigger) {
          const otherAnswer = t.closest('.faq-item')!.querySelector<HTMLElement>('.faq-answer')!;
          const otherIcon = t.querySelector<SVGElement>('.faq-icon')!;
          t.setAttribute('aria-expanded', 'false');
          otherAnswer.style.height = '0';
          otherIcon.style.transform = 'rotate(0deg)';
        }
      });

      if (isOpen) {
        trigger.setAttribute('aria-expanded', 'false');
        answer.style.height = '0';
        icon.style.transform = 'rotate(0deg)';
      } else {
        trigger.setAttribute('aria-expanded', 'true');
        answer.style.height = answer.scrollHeight + 'px';
        icon.style.transform = 'rotate(180deg)';
      }
    });
  });
</script>
