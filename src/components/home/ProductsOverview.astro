---
const products = [
  {
    name: 'Urbanice App',
    nameEN: 'Resident Mobile App',
    description: 'แอปลูกบ้านครบวงจร — ชำระค่าส่วนกลาง จองพื้นที่ส่วนกลาง แจ้งซ่อม และรับประกาศ ในที่เดียว',
    descEN: 'One app for everything residents need — payments, bookings, repairs, and announcements.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
    color: 'text-primary',
    bg: 'bg-primary-50',
    border: 'border-primary-100',
    href: '/solutions/urbanice',
    features: ['ชำระค่าส่วนกลาง', 'Facility Booking', 'Visitor E-Stamp', 'แจ้งซ่อม'],
  },
  {
    name: 'The LivingOS PMS',
    nameEN: 'Property Management System',
    description: 'ระบบจัดการนิติบุคคลสำหรับทีมงานอาคาร — บัญชี ใบแจ้งหนี้ ทะเบียนลูกบ้าน และรายงานครบถ้วน',
    descEN: 'Complete PMS for juristic teams — accounting, invoicing, resident directory, and reports.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>`,
    color: 'text-primary-600',
    bg: 'bg-primary-50',
    border: 'border-primary-100',
    href: '/solutions/pms',
    features: ['Billing & Accounts', 'Resident Directory', 'รายงานการเงิน', 'Dashboard นิติ'],
  },
  {
    name: 'GuardOS',
    nameEN: 'Security & Guard Management',
    description: 'ระบบรักษาความปลอดภัยอัจฉริยะ — ควบคุมผู้เยี่ยมชม บันทึก Patrol และแจ้งเตือน SOS แบบ Real-Time',
    descEN: 'Smart security suite — visitor control, patrol logging, and real-time SOS alerts.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    color: 'text-orange',
    bg: 'bg-orange-50',
    border: 'border-orange-100',
    href: '/solutions/guardos',
    features: ['i-Pass Visitor Control', 'i-Check Patrol', 'SOS Alerts', 'Smart Gate'],
  },
  {
    name: 'Services',
    nameEN: 'Professional Services',
    description: 'บริการเสริมครบวงจร — i-Vote สำหรับประชุมใหญ่ EIA Academy และงาน Turnkey สำหรับโครงการใหม่',
    descEN: 'AGM voting, EIA consulting, turnkey setup, and training academy for your team.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    color: 'text-success-600',
    bg: 'bg-success-50',
    border: 'border-success-600/20',
    href: '/solutions/services',
    features: ['i-Vote AGM', 'EIA Consulting', 'Turnkey Setup', 'Academy'],
  },
];
---

<section id="products" class="section-pad bg-warm-page">
  <div class="container-los">
    <!-- Header -->
    <div class="text-center mb-14 reveal-up">
      <div class="overline mb-3 text-text-4">Our Solutions</div>
      <h2 class="text-3xl lg:text-4xl font-bold text-text-1 mb-4">
        ทุกสิ่งที่โครงการต้องการ
      </h2>
      <p class="text-md text-text-3 font-light max-w-xl mx-auto">
        One integrated platform covering every aspect of property management — from residents to finances to security.
      </p>
    </div>

    <!-- Product cards grid -->
    <div class="grid md:grid-cols-2 gap-5 reveal-stagger">
      {products.map((p) => (
        <a
          href={p.href}
          class="group flex flex-col gap-5 p-6 bg-white border-1.5 border-warm-border-light rounded-xl shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200"
          style="border-width: 1.5px;"
        >
          <!-- Icon + name -->
          <div class="flex items-start gap-4">
            <div class={`w-11 h-11 rounded-lg flex items-center justify-center shrink-0 ${p.bg} ${p.color} border ${p.border}`}>
              <Fragment set:html={p.icon} />
            </div>
            <div>
              <div class="font-semibold text-lg text-text-1">{p.name}</div>
              <div class="text-xs text-text-4 font-mono mt-0.5">{p.nameEN}</div>
            </div>
          </div>

          <!-- Description -->
          <div>
            <p class="text-sm text-text-2 leading-relaxed">{p.description}</p>
            <p class="text-xs text-text-4 mt-1">{p.descEN}</p>
          </div>

          <!-- Feature chips -->
          <div class="flex flex-wrap gap-2 mt-auto">
            {p.features.map((f) => (
              <span class={`text-xs px-2.5 py-1 rounded-full border font-medium ${p.bg} ${p.border} ${p.color}`}>
                {f}
              </span>
            ))}
          </div>

          <!-- CTA link -->
          <div class={`flex items-center gap-1 text-sm font-medium ${p.color} group-hover:gap-2 transition-all`}>
            ดูเพิ่มเติม
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </div>
        </a>
      ))}
    </div>

    <!-- API Solution note -->
    <div class="mt-8 flex items-center justify-center gap-3 reveal-up">
      <div class="h-px flex-1 max-w-xs bg-warm-border-light"></div>
      <div class="flex items-center gap-2 px-4 py-2 rounded-full border border-warm-border-light bg-white text-sm text-text-3">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
        </svg>
        มี <span class="text-primary font-medium">API Solution</span> สำหรับนักพัฒนา
        <a href="/solutions/api" class="text-primary underline underline-offset-2">ดูรายละเอียด →</a>
      </div>
      <div class="h-px flex-1 max-w-xs bg-warm-border-light"></div>
    </div>
  </div>
</section>
