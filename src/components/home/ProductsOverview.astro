---
const products = [
  {
    name: 'Urbanice App',
    nameEN: 'Resident Mobile App',
    description: 'แอปลูกบ้านครบวงจร — ชำระค่าส่วนกลาง จองพื้นที่ส่วนกลาง แจ้งซ่อม และรับประกาศ ในที่เดียว',
    gradient: 'linear-gradient(153deg, #13A8AE -6.21%, #13A8AE 23.51%, #038D8F 61.53%)',
    href: '/solutions/urbanice',
    features: ['ชำระค่าส่วนกลาง', 'Facility Booking', 'Visitor E-Stamp', 'แจ้งซ่อม'],
  },
  {
    name: 'The LivingOS PMS',
    nameEN: 'Property Management System',
    description: 'ระบบจัดการนิติบุคคลสำหรับทีมงานอาคาร — บัญชี ใบแจ้งหนี้ ทะเบียนลูกบ้าน และรายงานครบถ้วน',
    gradient: 'linear-gradient(108deg, #1C70F7 6.04%, #104291 125.63%)',
    href: '/solutions/pms',
    features: ['Billing & Accounts', 'Resident Directory', 'รายงานการเงิน', 'Dashboard นิติ'],
  },
  {
    name: 'GuardOS',
    nameEN: 'Security & Guard Management',
    description: 'ระบบรักษาความปลอดภัยอัจฉริยะ — ควบคุมผู้เยี่ยมชม บันทึก Patrol และแจ้งเตือน SOS แบบ Real-Time',
    gradient: 'linear-gradient(153deg, #4D6DC3 -6.21%, #1E47B4 23.51%, #062986 61.53%)',
    href: '/solutions/guardos',
    features: ['i-Pass Visitor Control', 'i-Check Patrol', 'SOS Alerts', 'Smart Gate'],
  },
  {
    name: 'Services',
    nameEN: 'Professional Services',
    description: 'บริการเสริมครบวงจร — i-Vote สำหรับประชุมใหญ่ EIA Academy และงาน Turnkey สำหรับโครงการใหม่',
    gradient: 'linear-gradient(114deg, #FF6857 49.15%, #FAC554 125.81%)',
    href: '/solutions/services',
    features: ['i-Vote AGM', 'EIA Consulting', 'Turnkey Setup', 'Academy'],
  },
];
---

<section id="products" class="section-pad bg-warm-page">
  <div class="container-los">

    <!-- Header -->
    <div class="text-center mb-14 reveal-up">
      <div class="overline mb-3 text-text-4">Our Solutions</div>
      <h2 class="text-3xl lg:text-4xl font-bold text-text-1 mb-4">
        ทุกสิ่งที่โครงการต้องการ
      </h2>
      <p class="text-md text-text-3 font-light max-w-xl mx-auto">
        One integrated platform covering every aspect of property management — from residents to finances to security.
      </p>
    </div>

    <!-- Product cards grid -->
    <div class="grid md:grid-cols-2 gap-6 reveal-stagger">
      {products.map((p) => (
        <a href={p.href} class="folder-card group">

          <!-- Document sheets — slide up behind folder on hover -->
          <div class="folder-docs" aria-hidden="true">
            <div class="folder-doc doc-c"></div>
            <div class="folder-doc doc-a"></div>
            <div class="folder-doc doc-b"></div>
          </div>

          <!-- Folder tab (raised top-left edge) -->
          <div class="folder-tab"></div>

          <!-- Card body -->
          <div class="folder-body">

            <!-- Gradient thumbnail — framed inside card body -->
            <div class="folder-thumb-frame">
              <div class="folder-thumb" style={`background:${p.gradient}`}></div>
            </div>

            <!-- Content below thumbnail -->
            <div class="folder-content">

              <!-- Title badge — overlaps thumbnail bottom edge -->
              <div class="folder-title-badge">
                <span class="folder-title-text">{p.name}</span>
              </div>

              <!-- Description -->
              <p class="folder-desc">{p.description}</p>

              <!-- Feature chips -->
              <div class="folder-chips">
                {p.features.map(f => (
                  <span class="folder-chip">{f}</span>
                ))}
              </div>

              <!-- CTA row -->
              <div class="folder-cta">
                ดูเพิ่มเติม
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </div>

            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- API Solution note -->
    <div class="mt-10 flex items-center justify-center gap-3 reveal-up">
      <div class="h-px flex-1 max-w-xs bg-warm-border-light"></div>
      <div class="flex items-center gap-2 px-4 py-2 rounded-full border border-warm-border-light bg-white text-sm text-text-3">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
        </svg>
        มี <span class="text-primary font-medium">API Solution</span> สำหรับนักพัฒนา
        <a href="/solutions/api" class="text-primary underline underline-offset-2">ดูรายละเอียด →</a>
      </div>
      <div class="h-px flex-1 max-w-xs bg-warm-border-light"></div>
    </div>

  </div>
</section>

<style>
  /* ── Folder card wrapper ── */
  .folder-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    position: relative;
  }

  /* ── Document sheets behind folder ── */
  .folder-docs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: visible;
  }

  .folder-doc {
    position: absolute;
    background:
      repeating-linear-gradient(
        to bottom,
        #FFF3D9 0px,
        #FFF3D9 13px,
        #A1C2FF 13px,
        #A1C2FF 14px
      );
    border: 1.5px solid var(--color-warm-border-light);
    border-radius: 8px 8px 0 0;
    height: 90px;
    top: 28px; /* starts inside the folder, behind the tab */
    will-change: transform;
  }

  .doc-a {
    left: 6px;
    right: 14px;
    transform: translateY(0);
    transform-origin: bottom center;
    transition: transform 0.44s cubic-bezier(0.34, 1.3, 0.64, 1) 0.04s;
    z-index: 0;
  }

  .doc-b {
    left: 10px;
    right: 10px;
    transform: translateY(0);
    transform-origin: bottom right;
    transition: transform 0.44s cubic-bezier(0.34, 1.3, 0.64, 1);
    z-index: 0;
  }

  .doc-c {
    left: 10px;
    right: 14px;
    transform: translateY(0);
    transform-origin: bottom left;
    transition: transform 0.44s cubic-bezier(0.34, 1.3, 0.64, 1) 0.08s;
    z-index: 0;
  }

  .folder-card:hover .doc-a {
    transform: translateY(-38px) translateX(-8px) rotate(-9deg);
  }

  .folder-card:hover .doc-b {
    transform: translateY(-22px) translateX(4px) rotate(6deg);
  }

  .folder-card:hover .doc-c {
    transform: translateY(-29px) translateX(18px) rotate(20deg);
  }

  /* ── Raised tab (top-left) ── */
  .folder-tab {
    align-self: flex-start;
    width: 88px;
    height: 28px;
    background: #ffffff;
    border: 1.5px solid var(--color-warm-border-light);
    border-bottom: none;
    border-radius: 12px 12px 0 0;
    position: relative;
    z-index: 1;
    margin-bottom: -1.5px;
    transition: transform 0.3s ease;
  }

  /* ── Main card body ── */
  .folder-body {
    background: #ffffff;
    border: 1.5px solid var(--color-warm-border-light);
    border-radius: 0 16px 16px 16px;
    display: flex;
    flex-direction: column;
    flex: 1;
    position: relative;
    z-index: 1;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .folder-card:hover .folder-body,
  .folder-card:hover .folder-tab {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  /* ── Thumbnail frame (mat / padding around the image) ── */
  .folder-thumb-frame {
    padding: 8px 8px 0;
    flex-shrink: 0;
  }

  /* ── Gradient thumbnail ── */
  .folder-thumb {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
    height: 172px;
    border-radius: 10px;
    overflow: hidden;
  }

  /* ── Content area ── */
  .folder-content {
    padding: 0 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  /* ── Title badge overlapping thumbnail ── */
  .folder-title-badge {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    background: #ffffff;
    border-radius: 10px 10px 0 0;
    padding: 8px 14px;
    margin-top: -20px;
    margin-left: 4px;
    position: relative;
    z-index: 1;
  }

  .folder-title-text {
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text-1);
    line-height: 1;
  }

  /* ── Description ── */
  .folder-desc {
    font-size: 13px;
    color: var(--color-text-3);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Feature chips ── */
  .folder-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: auto;
  }

  .folder-chip {
    font-size: 11px;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 9999px;
    background: var(--color-white);
    border: 1.5px solid var(--color-warm-border-light);
    color: var(--color-text-3);
  }

  /* ── CTA link ── */
  .folder-cta {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
    transition: gap 0.15s ease;
    margin-top: 2px;
  }
  .folder-card:hover .folder-cta {
    gap: 9px;
  }
</style>
